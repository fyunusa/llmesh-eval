{
  "name": "llmesh/eval",
  "description": "LLMesh Evals - Pest/PHPUnit-native AI output testing framework",
  "type": "library",
  "license": "MIT",
  "repositories": [
    {
      "type": "path",
      "url": "../llmesh"
    }
  ],
  "require": {
    "php": "^8.1",
    "llmesh/core": "dev-main || ^0.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "suggest": {
    "pestphp/pest": "Required for Pest expectation toPassEval",
    "phpunit/phpunit": "Required for PHPUnit assertion traits"
  },
  "autoload": {
    "psr-4": {
      "LLMesh\\Eval\\": "src/"
    },
    "files": [
      "src/Assertions/PestExpectations.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "LLMesh\\Eval\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "lint": "vendor/bin/phpcs src tests --standard=PSR12 --warning-severity=0"
  }
}
